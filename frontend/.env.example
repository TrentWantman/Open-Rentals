# ===========================================
# Miami Rentals Frontend - Environment Config
# ===========================================
# Copy this file to .env.local and fill in your values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser

# ============ API CONFIG ============
# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============ MAPS ============
# Mapbox for property maps
# Get your token at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Mapbox style (optional - defaults to streets)
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12

# ============ GOOGLE ANALYTICS (Optional) ============
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# ============ SENTRY (Optional) ============
# For error tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# ============ FEATURE FLAGS (Optional) ============
NEXT_PUBLIC_ENABLE_CHAT=false
NEXT_PUBLIC_ENABLE_VIRTUAL_TOURS=false
