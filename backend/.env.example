# ===========================================
# Open Rentals Backend - Development Config
# ===========================================
# Copy this file to .env and fill in your values

# ============ SECURITY ============
# Generate a strong secret key for JWT signing
# Use: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this

# ============ DATABASE ============
# PostgreSQL connection string with asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://openrentals:yourpassword@postgres:5432/openrentals

# ============ REDIS (Optional) ============
# For caching and session storage
REDIS_URL=redis://localhost:6379/0

# ============ APP CONFIG ============
# Set to "false" in production
DEBUG=true

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ============ JWT CONFIG ============
# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ EMAIL (Optional) ============
# For sending verification emails, password resets, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@openrentals.dev
EMAILS_FROM_NAME=Open Rentals

# ============ FILE STORAGE ============
# Cloudinary for image uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# OR use AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=open-rentals-uploads

# ============ EXTERNAL APIS ============
# For address verification (optional)
GOOGLE_MAPS_API_KEY=your-google-maps-key

# For background checks on landlords (optional)
BACKGROUND_CHECK_API_KEY=your-api-key
